# Copy this file to .env on the server, then replace every value.

# MySQL
MYSQL_USER=kal
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password
# 拉取官方镜像超时（Docker Hub）时任选其一：
# 1) 服务器执行：bash deploy/configure-docker-mirror.sh 后重启 docker，再 compose up
# 2) 使用直连镜像代理（示例 DaoCloud）：
# MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.4
# MYSQL_IMAGE=mysql:8.4

# Backend security
KAL_JWT_SECRET=change-this-to-a-random-32-plus-character-secret

# Public URLs
KAL_CORS_ALLOWED_ORIGINS=http://47.238.235.51:3000
KAL_WEB_BASE_URL=http://47.238.235.51:3000

# Frontend local development
# Copy the next line into frontend-vue/.env.development when running npm run dev.
VITE_API_BASE=http://localhost:8080/api/v1

# Campus/user-space deployment defaults
# Used by deploy/user-space-deploy.sh when Docker/sudo are unavailable.
# Set PUBLIC_WEB_BASE_URL to the campus server IP or domain that users actually visit.
BACKEND_PORT=18080
FRONTEND_PORT=18000
PUBLIC_WEB_BASE_URL=http://YOUR_SERVER_IP:18000
PUBLIC_API_BASE=/api/v1

# Email
# Set KAL_MAIL_ENABLED=true only after SMTP works from the server.
KAL_MAIL_ENABLED=false
KAL_SMTP_HOST=smtp.163.com
KAL_SMTP_PORT=465
KAL_SMTP_USER=
KAL_SMTP_PASS=
KAL_MAIL_FROM=KAL 知行创坊 <no-reply@example.com>
