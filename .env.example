MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password

# Backend security
KAL_JWT_SECRET=change-this-to-a-random-32-plus-character-secret

# Public URLs
KAL_CORS_ALLOWED_ORIGINS=http://47.238.235.51:3000
